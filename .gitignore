### JetBrains IDE (PyCharm / IntelliJ / Android Studio) ###
# User-specific workspace (Never commit)
.idea/workspace.xml
.idea/usage.statistics.xml
.idea/shelf
.idea/dictionaries

# Android Studio specific (Added based on your screenshot)
.idea/deviceManager.xml
.idea/studiobot.xml
.idea/caches/

# Module settings (Generated files)
*.iml
.idea/modules.xml

### Android & Gradle Build Files (CRITICAL) ###
# Never commit the build output or the gradle cache
/build
/app/build
.gradle/

# Local configuration (SDK location, secrets) - NEVER COMMIT THIS
local.properties

### Python Specifics ###
# Compiled python files
__pycache__/
*.pyc

# Virtual Environments (Libraries)
venv/
.venv/
env/

# Environment files with credentials (NEVER COMMIT)
.env
*.env

### Operating System Junk ###
.DS_Store
Thumbs.db

### Flutter / Dart ###
# Build artifacts
flutter_app/build/
flutter_app/.dart_tool/
flutter_app/.flutter-plugins
flutter_app/.flutter-plugins-dependencies
flutter_app/.packages
flutter_app/.pub-cache/
flutter_app/.pub/

# Flutter metadata
flutter_app/.metadata

# Pubspec lock file (dependency versions - auto-generated)
flutter_app/pubspec.lock

# Generated code from build_runner
flutter_app/**/*.g.dart
flutter_app/**/*.freezed.dart
flutter_app/**/*.mocks.dart

# Coverage
flutter_app/coverage/

# Flutter version management
flutter_app/.flutter-version

# Generated plugin registrants (auto-generated by Flutter)
flutter_app/linux/flutter/generated_plugin_registrant.cc
flutter_app/linux/flutter/generated_plugin_registrant.h
flutter_app/linux/flutter/generated_plugins.cmake
flutter_app/macos/Flutter/GeneratedPluginRegistrant.swift
flutter_app/windows/flutter/generated_plugin_registrant.cc
flutter_app/windows/flutter/generated_plugin_registrant.h
flutter_app/windows/flutter/generated_plugins.cmake

# Platform-specific build artifacts (keep project config, ignore build output)
flutter_app/android/.gradle/
flutter_app/android/app/build/
flutter_app/android/build/
flutter_app/android/local.properties
flutter_app/android/key.properties
flutter_app/ios/
flutter_app/linux/
flutter_app/macos/
flutter_app/windows/
flutter_app/web/

# Test directory (if you want to keep tests, remove this line)
flutter_app/test/

# Obfuscation related
flutter_app/app.*.symbols

# Symbolication related
flutter_app/app.*.map.json

# Firebase & Google Services (if using Firebase)
flutter_app/android/app/google-services.json
flutter_app/ios/Runner/GoogleService-Info.plist
flutter_app/ios/firebase_app_id_file.json
flutter_app/lib/firebase_options.dart