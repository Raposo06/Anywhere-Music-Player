### JetBrains IDE (PyCharm / IntelliJ / Android Studio) ###
# User-specific workspace (Never commit)
.idea/workspace.xml
.idea/usage.statistics.xml
.idea/shelf
.idea/dictionaries

# Android Studio specific (Added based on your screenshot)
.idea/deviceManager.xml
.idea/studiobot.xml
.idea/caches/

# Module settings (Generated files)
*.iml
.idea/modules.xml

### Android & Gradle Build Files (CRITICAL) ###
# Never commit the build output or the gradle cache
/build
/app/build
.gradle/

# Local configuration (SDK location, secrets) - NEVER COMMIT THIS
local.properties

### Python Specifics ###
# Compiled python files
__pycache__/
*.pyc

# Virtual Environments (Libraries)
venv/
.venv/
env/

# Environment files with credentials (NEVER COMMIT)
.env
*.env
!*.env.example

### Operating System Junk ###
.DS_Store
Thumbs.db

