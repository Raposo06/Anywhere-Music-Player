# ============================================================================
# Anywhere Music Player - Uploader Configuration
# ============================================================================
# Copy this file to .env and fill in your actual values
# DO NOT commit .env to Git (it's in .gitignore)

# ----------------------------------------------------------------------------
# Music Library Settings
# ----------------------------------------------------------------------------
# Path to your local music folder (Windows example: C:\Music\Anime)
# (Linux/Mac example: /home/user/Music/Anime)
MUSIC_FOLDER=/path/to/your/music/folder

# ----------------------------------------------------------------------------
# MinIO Storage Settings
# ----------------------------------------------------------------------------
# MinIO endpoint (without https://)
MINIO_ENDPOINT=minio.yourdomain.com

# MinIO credentials (get from Coolify MinIO service)
MINIO_ACCESS_KEY=your-minio-access-key
MINIO_SECRET_KEY=your-minio-secret-key

# MinIO bucket name
MINIO_BUCKET=anime-music

# Use HTTPS for MinIO connection (true/false)
MINIO_SECURE=true

# ----------------------------------------------------------------------------
# PostgreSQL Database Settings
# ----------------------------------------------------------------------------
# Database host (use 'localhost' if using SSH tunnel)
DB_HOST=localhost

# Database port (default: 5432)
DB_PORT=5432

# Database name
DB_NAME=postgres

# Database user (default: postgres)
DB_USER=postgres

# Database password
DB_PASSWORD=your-postgres-password

# Database schema (musicplayer)
DB_SCHEMA=musicplayer

# ----------------------------------------------------------------------------
# Usage Notes
# ----------------------------------------------------------------------------
# 1. Copy this file: cp .env.example .env
# 2. Fill in your actual credentials
# 3. Run the uploader: python upload.py
#
# For SSH tunnel to database:
#   ssh -L 5432:localhost:5432 root@YOUR_HETZNER_IP
#   Then use DB_HOST=localhost
