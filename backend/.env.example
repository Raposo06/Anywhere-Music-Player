# Server Configuration
PORT=8000
API_BASE_URL=http://localhost:8000

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=your_postgres_password
DB_SCHEMA=musicplayer

# JWT Authentication
# Generate with: openssl rand -base64 32
JWT_SECRET=REPLACE_WITH_YOUR_JWT_SECRET_MIN_32_CHARS

# CORS Origins (comma-separated)
# For development: *
# For production: https://music.yourdomain.com,http://localhost:3000
CORS_ORIGINS=*

# Direct MinIO Streaming (optional)
# Set to "true" to bypass the proxy and stream directly from MinIO
# Requires CORS to be configured on MinIO bucket
# This improves seeking performance for large files
USE_DIRECT_MINIO_URLS=false
